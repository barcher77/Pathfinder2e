    desc: `The stylish duelist who builds <strong>Panache</strong> through daring feats and spends it on powerful Finishers. Swashbucklers are Dexterity-based melee fighters who thrive on momentum and flair, rewarded for taking risks, making theatrical moves, and finishing combos with high-impact flourishes. They're strong in one-on-one fights and have better social presence than most martial classes.`
  },
  {
    name: "Witch",
    pillar: "Social",
    role: "Debuffer / Caster",
    casting: "Varies by Patron",
    desc: `A spellcaster who gains power from a <strong>Patron</strong> — a mysterious entity that grants a familiar and determines their magical tradition. The Witch's familiar delivers their spells and Lessons (focus spells unique to their Patron), and the class has a strong "curse and debuff your enemies" identity alongside flexible tradition-based spellcasting. They're versatile, slightly sinister, and deeply familiar-dependent.`
  },
  {
    name: "Wizard",
    pillar: "Combat",
    role: "Controller / Caster",
    casting: "Arcane",
    desc: `The ultimate prepared arcane spellcaster. Wizards prepare spells from a massive <strong>spellbook</strong> each day and gain a Thesis that defines their unique magical approach. They know far more spells than any other class, can adapt their daily preparation to whatever the situation demands, and their School of Magic determines their bonus spells and specialization. The definitive master of magic through study.`
  },
];

// ══════════════════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════════════════
const grid = document.getElementById('class-grid');

CLASSES.forEach((cls, i) => {
  const entry = document.createElement('article');
  entry.className = 'class-entry';
  entry.dataset.name = cls.name.toLowerCase();
  entry.dataset.pillar = cls.pillar;

  entry.innerHTML = `
    <div class="entry-header">
      <h2 class="class-name">${cls.name}</h2>
      <div class="class-meta">
        <span class="meta-tag tag-pillar">${cls.pillar}</span>
        <span class="meta-tag tag-role">${cls.role}</span>
        ${cls.casting !== 'None' && !cls.casting.startsWith('None') ? `<span class="meta-tag tag-casting">${cls.casting}</span>` : ''}
      </div>
    </div>
    <p class="class-desc">${cls.desc}</p>
    <div class="entry-footer">— ✦ —</div>
  `;

  grid.appendChild(entry);

  // Add section dividers between groups
  const groups = [
    { after: 'Alchemist',    label: 'The Martial Arts' },
    { after: 'Bard',         label: 'The Divine Callings' },
    { after: 'Druid',        label: 'The Singular Few' },
    { after: 'Kineticist',   label: 'The Scholarly Arts' },
    { after: 'Oracle',       label: 'The Swift & Cunning' },
    { after: 'Rogue',        label: 'The Mystic Traditions' },
  ];
});

// ══════════════════════════════════════════════════════════════════
// FILTER & SEARCH
// ══════════════════════════════════════════════════════════════════
let activeFilter = 'all';
let searchVal = '';

function applyFilters() {
  const entries = document.querySelectorAll('.class-entry');
  let visible = 0;

  entries.forEach(entry => {
    const nameMatch = !searchVal || entry.dataset.name.includes(searchVal) ||
      entry.querySelector('.class-desc').textContent.toLowerCase().includes(searchVal);
    const pillarMatch = activeFilter === 'all' || entry.dataset.pillar === activeFilter;

    if (nameMatch && pillarMatch) {
      entry.classList.remove('hidden');
      visible++;
    } else {
      entry.classList.add('hidden');
    }
  });

  const noResults = document.getElementById('no-results');
  noResults.classList.toggle('visible', visible === 0);

  const countEl = document.getElementById('result-count');
  if (visible === CLASSES.length) {
    countEl.textContent = `${CLASSES.length} classes`;
  } else {
    countEl.textContent = `${visible} of ${CLASSES.length} classes`;
  }
}

// Search
document.getElementById('search').addEventListener('input', e => {
  searchVal = e.target.value.trim().toLowerCase();
  applyFilters();
});

// Pillar filter pills
document.querySelectorAll('.pill').forEach(pill => {
  pill.addEventListener('click', () => {
    activeFilter = pill.dataset.filter;
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    applyFilters();
  });
});
</script>
</body>
